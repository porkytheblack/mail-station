# ---------- Google OAuth client (one-time) ----------
# From GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs.
# The same client used to mint the REFRESH_TOKEN below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Google Cloud Pub/Sub (one-time) ----------
# Pull-type subscription. The TOPIC must grant
# gmail-api-push@system.gserviceaccount.com the roles/pubsub.publisher role,
# otherwise users.watch will fail with a permission error.
GCP_PROJECT_ID=
PUBSUB_TOPIC=projects/your-project-id/topics/your-topic-name
PUBSUB_SUBSCRIPTION=projects/your-project-id/subscriptions/your-pull-subscription-name

# ---------- Per-account (from your OAuth flow) ----------
# Refresh token must have scope https://www.googleapis.com/auth/gmail.readonly
# (or gmail.modify). Mint with access_type=offline & prompt=consent.
REGISTER_EMAIL=
REFRESH_TOKEN=

# ---------- Optional ----------
USER_ID=user-1
SQLITE_PATH=./e2e.db

# ---------- Resend (for the send:fixtures script) ----------
# Used only by `pnpm send:fixtures` to fire off test emails into the watched
# inbox. Sign up at resend.com and verify a domain.
# RESEND_FROM is the sender address; the local part is your choice but the
# domain must be verified.
RESEND_API_KEY=
RESEND_FROM=Mail Station Tests <tests@your-verified-domain.com>

# ---------- Pub/Sub credentials (NOT loaded by this app) ----------
# The Google Cloud Pub/Sub SDK uses Application Default Credentials.
# Provide them via either:
#   1) gcloud auth application-default login          (developer machines), or
#   2) export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# The service account / user must have roles/pubsub.subscriber on the
# subscription above.
